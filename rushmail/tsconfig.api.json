{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.api.tsbuildinfo",
		"target": "ES2022",
		"lib": [
			"ES2023"
		],
		"module": "CommonJS",
		"skipLibCheck": true,
		"moduleResolution": "node",
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"strict": false,
		"paths": {
			"@/*": [
				"./src/*"
			]
		}
	},
	"include": [
		"api/**/*",
		"src/api/**/*"
	]
}
